local function NoclipAndAntiFallHandler()
    local Character = LocalPlayer.Character
    if not Character then return end
    
    local HRP = Character:FindFirstChild("HumanoidRootPart")
    
    if getgenv().AutoDungeon then
        for _, Part in pairs(Character:GetDescendants()) do
            if Part:IsA("BasePart") and Part.CanCollide then
                Part.CanCollide = false
            end
        end
        
        if HRP then
            local AntiFall = HRP:FindFirstChild("SawitAntiFall")
            if not AntiFall then
                AntiFall = Instance.new("BodyVelocity")
                AntiFall.Name = "SawitAntiFall"
                AntiFall.MaxForce = Vector3.new(0, math.huge, 0)
                AntiFall.Velocity = Vector3.zero
                AntiFall.Parent = HRP
            end
        end
    else
        if HRP then
            local AntiFall = HRP:FindFirstChild("SawitAntiFall")
            if AntiFall then AntiFall:Destroy() end
        end
    end
end

