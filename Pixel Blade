local function AutoDungeonManager()
    while true do
        task.wait(0.2)
        if not getgenv().AutoDungeon then
            UpdateDebug("-")
            UpdateActionText("-")
            KorthWaiting = false
            CurrentBossMode = false
            TriggeredKorthSpawn = false
            TweenToPrisoner = false
            PrisonerTweenComplete = false
            StartDoorTweenComplete = false
            getgenv().IsTriggeringBoss = false
            getgenv().KillAuraMagnitude = getgenv().UserAuraMagnitude
            continue
        end

        pcall(function()
            if CurrentFPS < 10 then
                UpdateDebug("[Critical FPS] Pausing Auto Dungeon")
                if CurrentTween then CurrentTween:Cancel() CurrentTween = nil end
                task.wait(1)
                return
            end
            
            local IsCutscene, CutsceneMsg = GetCutsceneState()
            if IsCutscene then
                UpdateDebug("[Warning!] " .. CutsceneMsg)
                UpdateActionText("Idle")
                return
            end
            
            local Target, HasSpecial, SpecialRef, BookHands = GetTargetInfo()
            local Character = LocalPlayer.Character
            local CurrentWorldStr = "\nPlaying In: " .. FormatWorldName(GetWorldTypeRaw())
            local wt = GetWorldTypeRaw()
            
            if wt == "CrimsonAbyss" then
                local ThroneRoom = workspace:FindFirstChild("ThroneRoom")
                
                if ThroneRoom and not StartDoorTweenComplete and not TweenToPrisoner and not PrisonerTweenComplete and not TriggeredKorthSpawn and not CurrentBossMode then
                    getgenv().IsTriggeringBoss = true
                    UpdateDebug("Moving to Start" .. CurrentWorldStr)
                    UpdateActionText("Moving to StartDoor")
                    
                    local success = TweenToStartDoorAndWait()
                    
                    if success then
                        StartDoorTweenComplete = true
                    end
                    return
                end
                
                if ThroneRoom and StartDoorTweenComplete and not TweenToPrisoner and not PrisonerTweenComplete and not TriggeredKorthSpawn and not CurrentBossMode then
                    getgenv().IsTriggeringBoss = true
                    UpdateDebug("Moving To Trigger" .. CurrentWorldStr)
                    UpdateActionText("Moving to Trigger")
                    
                    local success = TweenToPrisonerAndWait()
                    
                    if success then
                        TweenToPrisoner = true
                        PrisonerTweenComplete = true
                    end
                    return
                end
                
                if PrisonerTweenComplete and not TriggeredKorthSpawn and not CurrentBossMode then
                    getgenv().IsTriggeringBoss = true
                    UpdateDebug("Waiting for Korth spawn.." .. CurrentWorldStr)
                    UpdateActionText("Waiting Boss Stuff")
                    
                    TriggeredKorthSpawn = true
                    KorthTriggerTime = os.clock()
                    return
                end
                
                if TriggeredKorthSpawn and not CurrentBossMode then
                    if os.clock() - KorthTriggerTime >= 5 then
                        KorthWaiting = true
                        CurrentBossMode = true
                        getgenv().KillAuraMagnitude = 50
                        TriggeredKorthSpawn = false
                        UpdateDebug("Killing : [Boss] Korth" .. CurrentWorldStr)
                        UpdateActionText("Delaying [Korth]")
                        KorthArrivalTime = os.clock()
                    else
                        UpdateActionText("Waiting For Korth")
                        return
                    end
                end
                
                if KorthWaiting and os.clock() - KorthArrivalTime >= 4 then
                    KorthWaiting = false
                    getgenv().IsTriggeringBoss = false
                end
                
                if KorthWaiting then return end
                
                if not KorthWaiting and SpecialRef and (string.find(string.lower(SpecialRef.Name), "localkorth") or string.find(string.lower(SpecialRef.Name), "corruptkorth")) and not string.find(string.lower(SpecialRef.Name), "korthend") then
                    if BookHands and #BookHands > 0 then
                        local AliveCount = 0
                        for _, bh in ipairs(BookHands) do
                            if GetEnemyHealth(bh) > 0 then
                                AliveCount = AliveCount + 1
                            end
                        end
                        
                        if AliveCount > 0 then
                            UpdateDebug("Killing : Book Hand (" .. AliveCount .. " remaining)" .. CurrentWorldStr)
                            UpdateActionText("Attacking Defender")
                        else
                            UpdateDebug("Killing : [Boss] Korth" .. CurrentWorldStr)
                            UpdateActionText("Attacking Korth")
                        end
                    else
                        UpdateDebug("Killing : [Boss] Korth" .. CurrentWorldStr)
                        UpdateActionText("Attacking Korth")
                    end
                    CurrentBossMode = true
                    getgenv().KillAuraMagnitude = 50
                    return
                end
            else
                getgenv().IsTriggeringBoss = false
                CurrentBossMode = false
                KorthWaiting = false
                TriggeredKorthSpawn = false
                TweenToPrisoner = false
                PrisonerTweenComplete = false
                StartDoorTweenComplete = false
                getgenv().KillAuraMagnitude = getgenv().UserAuraMagnitude
            end
            
            if Target and Character and Character:FindFirstChild("HumanoidRootPart") then
                LastEnemyTime = os.clock()
                TeleportedToExit = false
                UpdateStageText(Target)
                
                local FormattedName = FormatEnemyName(Target.Name)
                
                if IsBoss(Target.Name) then
                    BossDetectedThisWave = true
                    UpdateDebug("Killing : [Boss] " .. FormattedName .. CurrentWorldStr)
                else
                    UpdateDebug("Killing : " .. FormattedName .. CurrentWorldStr)
                end
                
                local TargetNameLower = string.lower(Target.Name)
                if string.find(TargetNameLower, "split") then
                    UpdateActionText("Engaging Problem")
                elseif string.find(TargetNameLower, "bookhand") then
                    UpdateActionText("Attacking Defender")
                else
                    UpdateActionText("Engaging")
                end
                
            else
                UpdateActionText("Idle")
                local EnemyCount = GetEnemyCount()
                if EnemyCount <= 0 then
                    if Character and Character:FindFirstChild("HumanoidRootPart") then
                        if CurrentStageText == "3/3" then
                            UpdateDebug("Dungeon Completed (3/3). Stopping." .. CurrentWorldStr)
                            if CurrentTween then CurrentTween:Cancel() CurrentTween = nil end
                        else
                            local TimeElapsed = os.clock() - LastEnemyTime
                            if not TeleportedToExit and TimeElapsed > 2 then
                                local ExitPart = GetNearestSpecific("exit")
                                if ExitPart then
                                    UpdateDebug("Finding Exit" .. CurrentWorldStr)
                                    TweenToTarget(ExitPart.Position + Vector3.new(0, 5, 0), 150)
                                    task.wait(3)
                                end
                                
                                if BossDetectedThisWave then
                                    local CampfirePart = GetNearestSpecific("campfire")
                                    if CampfirePart then
                                        UpdateDebug("Finding Nearest Campfire" .. CurrentWorldStr)
                                        TweenToTarget(CampfirePart.Position + Vector3.new(0, 5, 0), 150)
                                        task.wait(3)
                                    end
                                    BossDetectedThisWave = false
                                end
                                
                                TeleportedToExit = true
                                UpdateDebug("Waiting Next Area" .. CurrentWorldStr)
                            end
                        end
                    end
                end
            end
        end)
    end
end

