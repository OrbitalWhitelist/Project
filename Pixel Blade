local function GetTargetInfo()
    local Character = LocalPlayer.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return nil, false, nil, {} end
    
    local RootPos = Character.HumanoidRootPart.Position
    local wt = GetWorldTypeRaw()
    local PotentialTargets = workspace:GetChildren()
    
    if wt == "CrimsonAbyss" then
        local TR = workspace:FindFirstChild("ThroneRoom")
        local Prisoner = TR and TR:FindFirstChild("Prisoner")
        
        if Prisoner and not CurrentBossMode then
            return nil, false, nil, {}
        end
        
        if TR then
            for _, v in ipairs(TR:GetChildren()) do
                table.insert(PotentialTargets, v)
            end
        end
        
        local BookHandModels = {}
        local KorthModel = nil
        
        for _, v in ipairs(PotentialTargets) do
            if IsEnemy(v) then
                local nl = string.lower(v.Name)
                if string.find(nl, "bookhand") then
                    table.insert(BookHandModels, v)
                elseif (string.find(nl, "localkorth") or string.find(nl, "corruptkorth")) and not string.find(nl, "korthend") then
                    KorthModel = v
                end
            end
        end
        
        if #BookHandModels > 0 then
            local AliveBookHands = {}
            for _, bh in ipairs(BookHandModels) do
                if GetEnemyHealth(bh) > 0 then
                    table.insert(AliveBookHands, bh)
                end
            end
            
            if #AliveBookHands > 0 then
                return AliveBookHands[1], true, KorthModel, AliveBookHands
            elseif KorthModel then
                return KorthModel, false, nil, {}
            end
        elseif KorthModel then
            return KorthModel, false, nil, {}
        end
    end

    local AkumaModel = nil
    local ElderSorcererPresent = false
    
    if wt == "HauntedTundra" then
        ElderSorcererPresent = IsElderSorcererPresent()
        for _, v in ipairs(workspace:GetChildren()) do
            if IsEnemy(v) and string.find(string.lower(v.Name), "akuma") then
                AkumaModel = v
                break
            end
        end
        
        if ElderSorcererPresent then
            for _, v in ipairs(workspace:GetChildren()) do
                if IsEnemy(v) and string.find(string.lower(v.Name), "eldersorcerer") then
                    return v, true, AkumaModel, {}
                end
            end
        elseif AkumaModel then
            return AkumaModel, false, nil, {}
        end
    end
    
    local Closest = nil
    local MinDist = math.huge
    
    for _, v in ipairs(PotentialTargets) do
        if IsEnemy(v) then
            local Primary = GetPrimary(v)
            if Primary then
                local Dist = (RootPos - Primary.Position).Magnitude
                if Dist < MinDist then
                    MinDist = Dist
                    Closest = v
                end
            end
        end
    end
    
    return Closest, false, nil, {}
end

local function GetNearestSpecific(Keyword)
    local Character = LocalPlayer.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local RootPos = Character.HumanoidRootPart.Position
    local BestTarget = nil
    local MinDist = math.huge

    for _, v in ipairs(workspace:GetDescendants()) do
        local NameLower = string.lower(v.Name)
        if string.find(NameLower, Keyword) then
            local Part = nil
            if v:IsA("Model") then
                Part = GetPrimary(v)
            elseif v:IsA("BasePart") then
                Part = v
            end
            
            if Part then
                local Dist = (RootPos - Part.Position).Magnitude
                if Dist < MinDist and Dist > 15 then
                    MinDist = Dist
                    BestTarget = Part
                end
            end
        end
    end
    
    return BestTarget
end

local function TweenToTarget(TargetPos, Speed)
    local Character = LocalPlayer.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
    local HRP = Character.HumanoidRootPart
    
    if CurrentTween then
        CurrentTween:Cancel()
        CurrentTween = nil
    end
    
    local Dist = (HRP.Position - TargetPos).Magnitude
    local Time = Dist / (Speed or 150)
    
    local TInfo = TweenInfo.new(Time, Enum.EasingStyle.Linear)
    CurrentTween = TweenService:Create(HRP, TInfo, {CFrame = CFrame.new(TargetPos)})
    CurrentTween:Play()
    
    return Time
end

