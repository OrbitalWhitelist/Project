local function OrbitLogic(DeltaTime)
    if not getgenv().AutoDungeon then return end
    if CurrentFPS < 10 then return end
    if getgenv().IsTriggeringBoss then return end
    
    local IsCutscene = GetCutsceneState()
    if IsCutscene then return end
    
    local Target, HasSpecial, SpecialRef = GetTargetInfo()
    local Character = LocalPlayer.Character
    local OrbitTarget = Target
    
    if HasSpecial and SpecialRef and Target and string.find(string.lower(Target.Name), "bookhand") then
        local TR = workspace:FindFirstChild("ThroneRoom")
        local Korth = nil
        for _, v in ipairs(TR:GetChildren()) do
            local nl = string.lower(v.Name)
            if (string.find(nl, "localkorth") or string.find(nl, "corruptkorth")) and not string.find(nl, "korthend") then
                Korth = v
                break
            end
        end
        if Korth then
            OrbitTarget = Korth
        end
    end
    
    if OrbitTarget and Character and Character:FindFirstChild("HumanoidRootPart") and not KorthWaiting then
        local Primary = GetPrimary(OrbitTarget)
        if Primary then
            local HRP = Character.HumanoidRootPart
            local Dist = (HRP.Position - Primary.Position).Magnitude
            
            if CurrentBossMode then
                CurrentSafeDistance = BOSS_SAFE_DISTANCE
            else
                CurrentSafeDistance = NORMAL_SAFE_DISTANCE
            end
            
            if Dist > 50 then
                TweenToTarget(Primary.Position + Vector3.new(0, CurrentSafeDistance, 0), 100)
            else
                if CurrentTween then
                    CurrentTween:Cancel()
                    CurrentTween = nil
                end
                
                local SpeedToUse = 1.5
                OrbitAngle = (OrbitAngle + SpeedToUse * DeltaTime) % (2 * math.pi)
                local Offset = Vector3.new(math.cos(OrbitAngle) * ORBIT_RADIUS, CurrentSafeDistance, math.sin(OrbitAngle) * ORBIT_RADIUS)
                
                HRP.CFrame = CFrame.new(Primary.Position + Offset, Primary.Position)
            end
        end
    end
end

