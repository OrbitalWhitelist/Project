local function FormatChestName(Name)
    local baseName, tier = Name:match("^(.-)(%d+)$")
    if not baseName then
        baseName = Name
        tier = nil
    end
    local Formatted = baseName:gsub("(%l)(%u)", "%1 %2"):gsub("(%u)(%u%l)", "%1 %2"):gsub("^%l", string.upper)
    if tier then
        return Formatted .. " [Tier " .. tier .. "]"
    end
    return Formatted
end

local function FormatEnemyName(Name)
    local lowerName = string.lower(Name)
    lowerName = lowerName:gsub("%d+$", ""):match("^%s*(.-)%s*$")
    for key, val in pairs(NameDict) do
        if string.find(lowerName, key) then
            return val
        end
    end
    return Name:gsub("%d+$", ""):gsub("(%l)(%u)", "%1 %2"):gsub("^%l", string.upper)
end

local function RefreshChestList()
    local LootFolder = LocalPlayer:FindFirstChild("PlayerGui") and LocalPlayer.PlayerGui:FindFirstChild("gameUI") and LocalPlayer.PlayerGui.gameUI:FindFirstChild("armory") and LocalPlayer.PlayerGui.gameUI.armory:FindFirstChild("inventory") and LocalPlayer.PlayerGui.gameUI.armory.inventory:FindFirstChild("clip") and LocalPlayer.PlayerGui.gameUI.armory.inventory.clip:FindFirstChild("Loot")
    if LootFolder then
        local NewList = {}
        for _, Child in ipairs(LootFolder:GetChildren()) do
            if string.find(Child.Name, "Chest") then
                local DisplayName = FormatChestName(Child.Name)
                table.insert(NewList, {Name = Child.Name, Display = DisplayName})
            end
        end
        getgenv().ChestList = NewList
        return NewList
    end
    return {}
end

local function RefreshChestDropdown(Dropdown)
    local Chests = RefreshChestList()
    local DisplayNames = {}
    local Seen = {}
    for _, Chest in ipairs(Chests) do
        local dName = Chest.Display
        if Seen[dName] then
            Seen[dName] = Seen[dName] + 1
            dName = dName .. " (" .. Seen[dName] .. ")"
        else
            Seen[dName] = 1
        end
        Chest.Display = dName
        table.insert(DisplayNames, dName)
    end
    if #DisplayNames == 0 then
        table.insert(DisplayNames, "No Chests")
    end
    if Dropdown.Refresh then
        Dropdown:Refresh(DisplayNames)
    elseif Dropdown.SetValues then
        Dropdown:SetValues(DisplayNames)
    end
end

