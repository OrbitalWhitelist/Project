local function UpdateAuraSphere()
    if not getgenv().KillAuraEnabled then
        if AuraSphere then
            AuraSphere:Destroy()
            AuraSphere = nil
        end
        return
    end
    
    local Character = LocalPlayer.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
    
    if not AuraSphere then
        AuraSphere = Instance.new("Part")
        AuraSphere.Name = "AuraVisual"
        AuraSphere.Anchored = true
        AuraSphere.CanCollide = false
        AuraSphere.Transparency = 0.7
        AuraSphere.BrickColor = BrickColor.new("Lime green")
        AuraSphere.Material = Enum.Material.ForceField
        AuraSphere.Shape = Enum.PartType.Ball
        AuraSphere.Size = Vector3.new(1, 1, 1) * getgenv().KillAuraMagnitude * 2
        AuraSphere.Parent = workspace
    end
    
    AuraSphere.Size = Vector3.new(1, 1, 1) * getgenv().KillAuraMagnitude * 2
    AuraSphere.CFrame = Character.HumanoidRootPart.CFrame
    
    local Target = GetTargetInfo()
    local CurrentColor = Color3.new(0, 1, 0)
    
    local IsCutscene, _ = GetCutsceneState()
    if IsCutscene or getgenv().IsTriggeringBoss or KorthWaiting then
        CurrentColor = Color3.new(1, 0.5, 0)
    elseif Target then
        local Primary = GetPrimary(Target)
        if Primary then
            local Dist = (Character.HumanoidRootPart.Position - Primary.Position).Magnitude
            if Dist <= getgenv().KillAuraMagnitude then
                CurrentColor = Color3.new(1, 0, 0)
            end
        end
    end
    
    AuraSphere.Color = CurrentColor
end

local function KillAuraAction()
    while true do
        task.wait(0.05)
        if getgenv().KillAuraEnabled and not KorthWaiting and not getgenv().IsTriggeringBoss then
            pcall(function()
                local IsCutscene = GetCutsceneState()
                if IsCutscene then return end
                
                local Character = LocalPlayer.Character
                if not (Character and Character:FindFirstChild("HumanoidRootPart")) then return end
                local RootPos = Character.HumanoidRootPart.Position
                
                local Remote = ReplicatedStorage:FindFirstChild("remotes")
                if not (Remote and Remote:FindFirstChild("onHit")) then return end
                
                local wt = GetWorldTypeRaw()
                local IsTundra = (wt == "HauntedTundra")
                local IsCrimson = (wt == "CrimsonAbyss")
                local ElderSorcererPresent = IsTundra and IsElderSorcererPresent()
                local AkumaInAura = false
                local KorthInAura = false

                if IsTundra then
                    for _, v in ipairs(workspace:GetChildren()) do
                        if string.find(string.lower(v.Name), "akuma") then
                            local Primary = GetPrimary(v)
                            if Primary and (RootPos - Primary.Position).Magnitude <= tonumber(getgenv().KillAuraMagnitude) then
                                AkumaInAura = true
                                break
                            end
                        end
                    end
                elseif IsCrimson then
                    local TR = workspace:FindFirstChild("ThroneRoom")
                    if TR then
                        for _, v in ipairs(TR:GetChildren()) do
                            local nl = string.lower(v.Name)
                            if (string.find(nl, "localkorth") or string.find(nl, "corruptkorth")) and not string.find(nl, "korthend") then
                                local Primary = GetPrimary(v)
                                if Primary and (RootPos - Primary.Position).Magnitude <= tonumber(getgenv().KillAuraMagnitude) then
                                    KorthInAura = true
                                end
                            end
                        end
                    end
                end

                local TargetsToHit = {}
                local MainTarget, HasSpecial, SpecialRef, BookHands = GetTargetInfo()

                local function IsValidTarget(model)
                    if string.find(string.lower(model.Name), "prisoner") then return false end
                    if IsEnemy(model) or IsCrate(model) then
                        return true
                    end
                    local nameLower = string.lower(model.Name)
                    if string.find(nameLower, "split") then
                        local health = GetEnemyHealth(model)
                        return health > 0
                    end
                    return false
                end

                if IsCrimson and HasSpecial and BookHands then
                    for _, bh in ipairs(BookHands) do
                        if GetEnemyHealth(bh) > 0 then
                            table.insert(TargetsToHit, bh)
                        end
                    end
                elseif getgenv().AuraStyle == "Slow" then
                    if MainTarget and IsValidTarget(MainTarget) then
                        table.insert(TargetsToHit, MainTarget)
                    end
                else
                    local PotentialTargets = workspace:GetChildren()
                    if IsCrimson then
                        local TR = workspace:FindFirstChild("ThroneRoom")
                        if TR then
                            for _, v in ipairs(TR:GetChildren()) do
                                table.insert(PotentialTargets, v)
                            end
                        end
                    end
                    for _, v in ipairs(PotentialTargets) do
                        if IsValidTarget(v) then
                            table.insert(TargetsToHit, v)
                        end
                    end
                end

                for _, v in ipairs(TargetsToHit) do
                    local Primary = GetPrimary(v)
                    local NameLower = string.lower(v.Name)
                    local Dist = Primary and (RootPos - Primary.Position).Magnitude or math.huge
                    local IsBookHand = string.find(NameLower, "bookhand")

                    local CanHit = false
                    if Dist <= tonumber(getgenv().KillAuraMagnitude) then
                        CanHit = true
                    elseif IsBookHand and CurrentBossMode then
                        CanHit = true
                    end

                    if CanHit then
                        if ElderSorcererPresent and string.find(NameLower, "akuma") then
                            AuraEntryTimes[v] = nil
                        else
                            if not AuraEntryTimes[v] then
                                AuraEntryTimes[v] = os.clock()
                            end
                            
                            local RequiredDelay = 0
                            
                            if AkumaInAura or KorthInAura then
                                RequiredDelay = 2
                            else
                                RequiredDelay = 0.1
                            end
                            
                            if IsBookHand then
                                RequiredDelay = 0.1
                            end
                            
                            if os.clock() - AuraEntryTimes[v] >= RequiredDelay then
                                local TargetObj = v:FindFirstChildOfClass("Humanoid") or v:FindFirstChild("Health") or v
                                local EnemyHP = GetEnemyHealth(v)
                                local FireTimes = EnemyHP > 100 and 2 or 1
                                
                                local DamageValue = 999
                                if string.find(NameLower, "split") then
                                    DamageValue = 393.3
                                elseif string.find(NameLower, "bookhand") then
                                    DamageValue = 427.125
                                end
                                
                                for i = 1, FireTimes do
                                    pcall(function()
                                        Remote.onHit:FireServer(TargetObj, DamageValue, {}, 0)
                                    end)
                                end
                                
                                if IsBookHand then
                                    AuraEntryTimes[v] = os.clock()
                                end
                            end
                        end
                    else
                        AuraEntryTimes[v] = nil
                    end
                end
            end)
        end
    end
end

