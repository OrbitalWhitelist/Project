local function GetCutsceneState()
    local CutsceneObj = workspace:FindFirstChild("inCutscene")
    if CutsceneObj and CutsceneObj:IsA("BoolValue") and CutsceneObj.Value == true then
        CutsceneWaitUntil = os.clock() + 6
        return true, "[Cutscene] - Delaying.."
    end
    if os.clock() < CutsceneWaitUntil then
        local Remaining = math.ceil(CutsceneWaitUntil - os.clock())
        return true, string.format("Cutscene ended. Resuming in %d seconds...", Remaining)
    end
    return false, ""
end

local function GetPrimary(Model)
    if not Model then return nil end
    if Model:IsA("BasePart") then return Model end
    local p = Model.PrimaryPart or Model:FindFirstChild("HumanoidRootPart") or Model:FindFirstChild("Torso") or Model:FindFirstChild("Head") or Model:FindFirstChild("basehitbox")
    if p then return p end
    for _, child in ipairs(Model:GetChildren()) do
        if child:IsA("BasePart") then return child end
    end
    return nil
end

local function IsBoss(ModelName)
    local NameLower = string.lower(ModelName)
    for _, bossName in ipairs(BossList) do
        if string.find(NameLower, bossName) then return true end
    end
    return false
end

local function IsElderSorcererPresent()
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Model") and string.find(string.lower(v.Name), "eldersorcerer") then
            local HealthObj = v:FindFirstChild("Health")
            local Hum = v:FindFirstChildOfClass("Humanoid")
            if (HealthObj and (HealthObj:IsA("NumberValue") or HealthObj:IsA("IntValue")) and HealthObj.Value > 0) or (Hum and Hum.Health > 0) then
                return true
            end
        end
    end
    return false
end

local function IsEnemy(Model)
    if not Model or not Model.Parent then return false end
    if Players:GetPlayerFromCharacter(Model) then return false end
    
    local NameLower = string.lower(Model.Name)
    if string.find(NameLower, "rig") then return false end
    if string.find(NameLower, "teeth") then return false end
    if string.find(NameLower, "breakable") then return false end
    if string.find(NameLower, "snowfalling") then return false end
    if string.find(NameLower, "ashfalling") then return false end
    if string.find(NameLower, "korthend") then return false end
    
    if string.find(NameLower, "bookhand") then return true end
    if string.find(NameLower, "korth") then return true end
    if string.find(NameLower, "corruptfleshgiant") then return true end
    if string.find(NameLower, "splitleft") or string.find(NameLower, "splitright") then return true end
    
    local HealthObj = Model:FindFirstChild("Health")
    if HealthObj and (HealthObj:IsA("NumberValue") or HealthObj:IsA("IntValue")) and HealthObj.Value > 0 then
        return true
    end
    
    local Hum = Model:FindFirstChildOfClass("Humanoid")
    if Hum and Hum.Health > 0 then return true end
    
    return false
end

local function IsCrate(Model)
    if not Model then return false end
    if string.find(string.lower(Model.Name), "breakable") then return true end
    return false
end

local function GetEnemyHealth(Model)
    local HealthObj = Model:FindFirstChild("Health")
    if HealthObj and (HealthObj:IsA("NumberValue") or HealthObj:IsA("IntValue")) then
        return math.floor(HealthObj.Value)
    end
    local Hum = Model:FindFirstChildOfClass("Humanoid")
    if Hum then return math.floor(Hum.Health) end
    return 0
end

